{
  "name": "fund-clicker-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create fund-clicker-platform",
    "db:migrate": "wrangler d1 execute fund-clicker-platform --remote --file=./migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute fund-clicker-platform --local --file=./migrations/0001_initial.sql",
    "test": "node --test"
  },
  "devDependencies": {
    "wrangler": "^4.74.0"
  }
}
